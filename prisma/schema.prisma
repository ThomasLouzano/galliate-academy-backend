generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  cargo     String
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())
}

model Modulo {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())
}

model Progresso {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  moduloId  Int
  concluido Boolean  @default(false)
  criadoEm DateTime @default(now())
}