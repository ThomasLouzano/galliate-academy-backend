generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             Int       @id @default(autoincrement())
  nome           String
  email          String    @unique
  senha          String
  cargo          String
  telefone       String?
  ativo          Boolean   @default(true)
  xp             Int       @default(0)
  criadoEm      DateTime  @default(now())
  resetToken     String?
  resetTokenExp  DateTime?
}

model Trilha {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  icone     String   @default("📋")
  ordem     Int      @default(0)
  criadoEm DateTime @default(now())
  modulos   Modulo[]
}

model Modulo {
  id         Int         @id @default(autoincrement())
  titulo     String
  descricao  String?
  ativo      Boolean     @default(true)
  xpBonus    Int         @default(50)
  trilhaId   Int?
  trilha     Trilha?     @relation(fields: [trilhaId], references: [id], onDelete: SetNull)
  criadoEm  DateTime    @default(now())
  secoes     Secao[]
  avaliacoes Avaliacao[]
}

model Secao {
  id        Int      @id @default(autoincrement())
  titulo    String
  ordem     Int      @default(0)
  moduloId  Int
  modulo    Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  aulas     Aula[]
  criadoEm DateTime  @default(now())
}

model Aula {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  videoUrl  String?
  ordem     Int      @default(0)
  duracao   String?
  checklist   String?
  apostilaUrl String?
  xp          Int      @default(10)
  secaoId     Int
  secao     Secao    @relation(fields: [secaoId], references: [id], onDelete: Cascade)
  criadoEm DateTime  @default(now())
}

model Avaliacao {
  id         Int       @id @default(autoincrement())
  titulo     String
  moduloId   Int?
  modulo     Modulo?   @relation(fields: [moduloId], references: [id], onDelete: SetNull)
  notaMinima Int       @default(70)
  tentativas Int       @default(3)
  xpBonus    Int       @default(100)
  criadoEm  DateTime  @default(now())
  questoes   Questao[]
}

model Questao {
  id              Int       @id @default(autoincrement())
  enunciado       String
  tipo            String    @default("multipla")
  alternativas    String?
  respostaCorreta String
  peso            Int       @default(1)
  avaliacaoId     Int
  avaliacao       Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  criadoEm       DateTime  @default(now())
}

model Certificado {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  moduloId        Int
  avaliacaoId     Int?
  nota            Float?
  cargaHoraria    Float    @default(1)
  emitidoEm       DateTime @default(now())
  codigoValidacao String   @unique
}

model Progresso {
  id          Int       @id @default(autoincrement())
  usuarioId   Int
  aulaId      Int?
  concluida   Boolean   @default(false)
  concluidoEm DateTime?
  criadoEm    DateTime  @default(now())

  @@unique([usuarioId, aulaId])
}