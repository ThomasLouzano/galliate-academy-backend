generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  cargo     String
  telefone  String?
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())
}

model Trilha {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  icone     String   @default("📋")
  ordem     Int      @default(0)
  criadoEm DateTime @default(now())
  modulos   Modulo[]
}

model Modulo {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  ativo     Boolean  @default(true)
  trilhaId  Int?
  trilha    Trilha?  @relation(fields: [trilhaId], references: [id], onDelete: SetNull)
  criadoEm DateTime @default(now())
  secoes    Secao[]
}

model Secao {
  id        Int      @id @default(autoincrement())
  titulo    String
  ordem     Int      @default(0)
  moduloId  Int
  modulo    Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  aulas     Aula[]
  criadoEm DateTime  @default(now())
}

model Aula {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  videoUrl  String?
  ordem     Int      @default(0)
  duracao   String?
  checklist String?
  secaoId   Int
  secao     Secao    @relation(fields: [secaoId], references: [id], onDelete: Cascade)
  criadoEm DateTime  @default(now())
}

model Progresso {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  moduloId  Int
  concluido Boolean  @default(false)
  criadoEm DateTime @default(now())
}